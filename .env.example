# ── Shopify ──────────────────────────────────────────────────────────────────
# From your Shopify Partner Dashboard → App → API credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Your app's public URL (no trailing slash)
# Local: use ngrok, e.g. https://abc123.ngrok.io
# Production: https://doomling.vercel.app
HOST=https://doomling.vercel.app

# Exposed to the browser — same value as SHOPIFY_API_KEY
NEXT_PUBLIC_SHOPIFY_API_KEY=your_shopify_api_key

# ── Firebase (server-only, never expose to browser) ──────────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as shown in the JSON file.
# In Vercel, paste with literal \n — Vercel handles the newlines automatically.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
