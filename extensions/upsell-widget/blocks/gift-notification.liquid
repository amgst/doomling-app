{% comment %} Gift with Purchase — Cart Notification Block {% endcomment %}

{%- comment -%}
  SSR pass: collect any gift line items (marked with _gwp=1 property by CartTransform).
  This renders immediately on the cart PAGE (full-page render).
  The JavaScript block below handles the cart DRAWER and any AJAX cart updates.
{%- endcomment -%}

{%- assign gwp_has_gift = false -%}
{%- assign gwp_gift_data = '' -%}
{%- for item in cart.items -%}
  {%- if item.properties['_gwp'] == '1' -%}
    {%- assign gwp_has_gift = true -%}
    {%- assign gwp_img = '' -%}
    {%- if item.image -%}
      {%- assign gwp_img = item.image | image_url: width: 80 -%}
    {%- endif -%}
    {%- assign gwp_gift_data = gwp_gift_data | append: item.product_title | append: ':::' | append: gwp_img | append: '|||' -%}
  {%- endif -%}
{%- endfor -%}

<div
  id="gwp-notif-root"
  data-notification-text="{{ settings.notification_text | default: "You've earned a free gift!" | escape }}"
  data-toast-text="{{ settings.toast_text | default: "Free gift added!" | escape }}"
  data-shop="{{ shop.permanent_domain }}"
  data-api-base-url="{{ settings.api_base_url | default: "https://upsale-cyan.vercel.app" | escape }}"
  data-cart-section-ids="{{ settings.cart_section_ids | default: "main-cart-items,main-cart-footer" | escape }}"
  data-enable-celebration="{% if settings.enable_celebration %}true{% else %}false{% endif %}"
  data-embedded-rules="{{ shop.metafields.gwp.gift_rules.value | default: '' | escape }}"
>

<style>
#gwp-notif-root * { box-sizing: border-box; }

.gwp-banner {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin: 0.75rem 0;
}

.gwp-banner-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-left: 4px solid #16a34a;
  border-radius: 10px;
  padding: 0.75rem 1rem;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  animation: gwp-slidein 0.3s ease;
}

@keyframes gwp-slidein {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.gwp-banner-img {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  object-fit: cover;
  flex-shrink: 0;
  border: 2px solid #d1fae5;
}

.gwp-banner-icon {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  background: #dcfce7;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  flex-shrink: 0;
}

.gwp-banner-text {
  flex: 1;
  min-width: 0;
}

.gwp-banner-text strong {
  display: block;
  font-size: 0.85rem;
  font-weight: 700;
  color: #15803d;
  margin: 0 0 0.1rem;
}

.gwp-banner-text span {
  font-size: 0.8rem;
  color: #166534;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 220px;
}

.gwp-banner-free-badge {
  flex-shrink: 0;
  background: #16a34a;
  color: #fff;
  font-size: 0.68rem;
  font-weight: 800;
  padding: 0.2rem 0.55rem;
  border-radius: 20px;
  letter-spacing: 0.05em;
}

/* ── Toast ──────────────────────────────────────────────────────────────── */

#gwp-toast {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 99999;
  background: #fff;
  border: 1px solid #bbf7d0;
  border-left: 4px solid #16a34a;
  border-radius: 14px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.14), 0 2px 8px rgba(22, 163, 74, 0.12);
  padding: 0.85rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  max-width: 310px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  transform: translateY(calc(100% + 2.5rem));
  opacity: 0;
  transition: transform 0.4s cubic-bezier(0.34, 1.4, 0.64, 1), opacity 0.25s ease;
  pointer-events: none;
}

#gwp-toast.gwp-toast--visible {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

/* —— Confetti overlay —— */
#gwp-confetti {
  position: fixed;
  inset: 0;
  z-index: 100000;
  pointer-events: none;
  overflow: hidden;
  display: none;
}
#gwp-confetti.gwp-confetti--visible { display: block; }
.gwp-confetti-piece {
  position: absolute;
  top: -10px;
  width: 10px;
  height: 14px;
  border-radius: 2px;
  opacity: 0.95;
  animation: gwp-confetti-fall 900ms linear forwards;
}
@keyframes gwp-confetti-fall {
  0%   { transform: translate3d(0, 0, 0) rotate(0deg); }
  100% { transform: translate3d(var(--dx), calc(100vh + 40px), 0) rotate(var(--rot)); }
}

.gwp-toast-emoji {
  font-size: 1.5rem;
  flex-shrink: 0;
  line-height: 1;
}

.gwp-toast-body {
  flex: 1;
  min-width: 0;
}

.gwp-toast-body strong {
  display: block;
  font-size: 0.875rem;
  font-weight: 700;
  color: #15803d;
  margin: 0 0 0.1rem;
}

.gwp-toast-body span {
  font-size: 0.78rem;
  color: #4b5563;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gwp-toast-close {
  background: none;
  border: none;
  color: #9ca3af;
  font-size: 1rem;
  cursor: pointer;
  padding: 0.1rem 0.2rem;
  flex-shrink: 0;
  line-height: 1;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
}

.gwp-toast-close:hover {
  color: #374151;
  background: #f3f4f6;
}

@media (max-width: 480px) {
  #gwp-toast {
    left: 0.75rem;
    right: 0.75rem;
    max-width: none;
    bottom: 0.75rem;
  }
}
</style>

{%- comment -%} SSR banner — rendered on cart page full-page load {%- endcomment -%}
{%- if gwp_has_gift -%}
  {%- assign gwp_entries = gwp_gift_data | split: '|||' -%}
  <div class="gwp-banner" id="gwp-banner-ssr">
    {%- for gwp_entry in gwp_entries -%}
      {%- if gwp_entry != '' -%}
        {%- assign gwp_parts = gwp_entry | split: ':::' -%}
        {%- assign gwp_title = gwp_parts[0] -%}
        {%- assign gwp_img_url = gwp_parts[1] -%}
        <div class="gwp-banner-item">
          {%- if gwp_img_url != '' -%}
            <img class="gwp-banner-img" src="{{ gwp_img_url }}" alt="{{ gwp_title | escape }}" loading="lazy" width="44" height="44" />
          {%- else -%}
            <span class="gwp-banner-icon">🎁</span>
          {%- endif -%}
          <div class="gwp-banner-text">
            <strong>{{ settings.notification_text | default: "You've earned a free gift!" }}</strong>
            <span>{{ gwp_title }} added to your cart for free.</span>
          </div>
          <span class="gwp-banner-free-badge">FREE</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}

{%- comment -%} JS-powered banner — shown for cart drawer & AJAX updates {%- endcomment -%}
<div class="gwp-banner" id="gwp-banner-js" style="display:none;"></div>

{%- comment -%} Toast — fixed overlay, auto-dismisses after 5s {%- endcomment -%}
<div id="gwp-toast" role="status" aria-live="polite" aria-atomic="true"></div>
<div id="gwp-confetti" aria-hidden="true"></div>

</div><!-- #gwp-notif-root -->

<script>
(function () {
  function getRoot() { return document.getElementById('gwp-notif-root'); }
  var root = getRoot();
  if (!root) return;

  var PROP_KEY = '_gwp';
  var PROP_VAL = '1';

  function getNotifText() {
    var r = getRoot();
    return (r && r.dataset.notificationText) || "You\u2019ve earned a free gift!";
  }

  function getToastText() {
    var r = getRoot();
    return (r && r.dataset.toastText) || "Free gift added!";
  }

  var shop = root.dataset.shop || '';
  var apiBaseUrl = (root.dataset.apiBaseUrl || '').replace(/\/$/, '');
  var cartSectionIds = (root.dataset.cartSectionIds || '')
    .split(',')
    .map(function (s) { return (s || '').trim(); })
    .filter(Boolean);

  function getEnableCelebration() {
    var r = getRoot();
    return !!(r && r.dataset.enableCelebration === 'true');
  }

  function getCartSectionIds() {
    var existing = cartSectionIds.filter(function (id) { return !!document.getElementById('shopify-section-' + id); });
    if (existing.length > 0) return existing;

    var onCartPage = !!(window.location && /^\/cart\b/i.test(window.location.pathname || ''));

    if (onCartPage) {
      var common = ['main-cart-items', 'main-cart-footer'];
      var commonExisting = common.filter(function (id) { return !!document.getElementById('shopify-section-' + id); });
      if (commonExisting.length > 0) return commonExisting;
    } else {
      // Drawer/header updates (Dawn + similar themes)
      var drawerPreferred = ['cart-drawer', 'cart-icon-bubble', 'cart-live-region-text', 'cart-notification'];
      var drawerExisting = drawerPreferred.filter(function (id) { return !!document.getElementById('shopify-section-' + id); });
      if (drawerExisting.length > 0) return drawerExisting.slice(0, 3);
    }

    var detected = Array.prototype.slice.call(document.querySelectorAll('[id^="shopify-section-"]'))
      .map(function (el) { return String(el.id || '').replace(/^shopify-section-/, ''); })
      .filter(function (id) { return id && /(cart|drawer|bubble|icon)/i.test(id); });

    return detected.length > 0 ? detected.slice(0, 3) : cartSectionIds;
  }

  var rulesCache = null;
  var rulesPromise = null;
  var rulesStorageKey = shop ? ('gwp_rules_cache_v1:' + shop) : 'gwp_rules_cache_v1';
  var rulesStorageTtlMs = 5 * 60 * 1000;
  var rulesBootstrapPending = false;

  function readCachedRules() {
    try {
      var raw = sessionStorage.getItem(rulesStorageKey);
      if (!raw) return null;
      var parsed = JSON.parse(raw);
      if (!parsed || !Array.isArray(parsed.rules)) return null;
      var age = Date.now() - (Number(parsed.ts) || 0);
      return { rules: parsed.rules, stale: !(age >= 0 && age < rulesStorageTtlMs) };
    } catch (e) {
      return null;
    }
  }

  function writeCachedRules(rules) {
    try {
      sessionStorage.setItem(rulesStorageKey, JSON.stringify({ ts: Date.now(), rules: rules }));
    } catch (e) {}
  }

  function fetchRulesNetwork(timeoutMs) {
    if (!apiBaseUrl || !shop) return Promise.resolve([]);

    var ctrl = null;
    var t = null;
    try {
      ctrl = new AbortController();
      if (timeoutMs && timeoutMs > 0) {
        t = setTimeout(function () { try { ctrl.abort(); } catch (e) {} }, timeoutMs);
      }
    } catch (e) {}

    function doFetch(path) {
      return fetch(apiBaseUrl + path + '?shop=' + encodeURIComponent(shop), {
        method: 'GET',
        mode: 'cors',
        credentials: 'omit',
        cache: 'default',
        signal: ctrl ? ctrl.signal : undefined,
      })
        .then(function (r) { return r.ok ? r.json() : { rules: [] }; })
        .then(function (data) { return (data && data.rules) || []; });
    }

    // Prefer the newer cached endpoint.
    return doFetch('/api/gwp-rules-v2')
      .finally(function () { if (t) clearTimeout(t); });
  }

  function loadRules() {
    if (rulesCache) return Promise.resolve(rulesCache);
    if (rulesPromise) return rulesPromise;
    if (!apiBaseUrl || !shop) {
      rulesCache = [];
      return Promise.resolve(rulesCache);
    }

    var embeddedRaw = '';
    try { embeddedRaw = String(getRoot().dataset.embeddedRules || '').trim(); } catch (e) {}
    if (embeddedRaw) {
      try {
        var embedded = JSON.parse(embeddedRaw);
        var embeddedRules = (embedded && embedded.rules) ? embedded.rules : embedded;
        if (Array.isArray(embeddedRules)) {
          rulesCache = embeddedRules;
          writeCachedRules(rulesCache);
          return Promise.resolve(rulesCache);
        }
      } catch (e) {}
    }

    var cached = readCachedRules();
    if (cached && Array.isArray(cached.rules)) {
      rulesCache = cached.rules;
      if (cached.stale) {
        fetchRulesNetwork(1200)
          .then(function (rules) {
            if (Array.isArray(rules) && rules.length > 0) {
              rulesCache = rules;
              writeCachedRules(rules);
              checkCart(0);
            }
          })
          .catch(function () {});
      }
      return Promise.resolve(rulesCache);
    }

    rulesBootstrapPending = true;
    rulesPromise = fetchRulesNetwork(12_000)
      .then(function (rules) {
        rulesCache = Array.isArray(rules) ? rules : [];
        writeCachedRules(rulesCache);
        if (rulesBootstrapPending) {
          rulesBootstrapPending = false;
          checkCart(0);
        }
        return rulesCache;
      })
      .catch(function () {
        rulesCache = [];
        return rulesCache;
      })
      .finally(function () { rulesPromise = null; });

    return rulesPromise;
  }

  function cartEndpoint(path) {
    var rootRoute = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    rootRoute = rootRoute || '/';
    if (rootRoute[rootRoute.length - 1] !== '/') rootRoute += '/';
    path = String(path || '').replace(/^\//, '');
    return rootRoute + path;
  }

  function postCart(path, payload) {
    var body = payload || {};

    // Request section HTML in the same cart API call (Dawn pattern)
    // for faster + more reliable cart UI updates.
    var sectionIds = getCartSectionIds();
    if (Array.isArray(sectionIds) && sectionIds.length > 0) {
      body.sections = sectionIds.join(',');
      var p = (window.location && window.location.pathname) ? String(window.location.pathname) : '/cart';
      var q = (window.location && window.location.search) ? String(window.location.search) : '';
      body.sections_url = p + q;
    }

    return fetch(path, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-GWP-Internal': '1' },
      body: JSON.stringify(body),
    }).then(function (r) { return r.ok ? r.json() : null; });
  }

  var syncInFlight = false;
  var syncQueued = false;
  var cartReloadKeyPrefix = 'gwp_cart_reload_v1:';

  function getCartQtyByVariant(cart, variantId) {
    var items = (cart && cart.items) || [];
    var total = 0;
    for (var i = 0; i < items.length; i++) {
      if (String(items[i].variant_id) === String(variantId)) total += (items[i].quantity || 0);
    }
    return total;
  }

  function getAutoGiftLines(cart, giftVariantId) {
    var items = (cart && cart.items) || [];
    var matches = [];
    for (var i = 0; i < items.length; i++) {
      var it = items[i];
      if (String(it.variant_id) !== String(giftVariantId)) continue;
      var props = it.properties || {};
      if (props[PROP_KEY] !== PROP_VAL) continue;
      matches.push(it);
    }
    return matches;
  }

  function hasManualGift(cart, giftVariantId) {
    var items = (cart && cart.items) || [];
    for (var i = 0; i < items.length; i++) {
      var it = items[i];
      if (String(it.variant_id) !== String(giftVariantId)) continue;
      var props = it.properties || {};
      if (props[PROP_KEY] === PROP_VAL) continue;
      return true;
    }
    return false;
  }

  function syncGifts(cart, rules) {
    if (!Array.isArray(rules) || rules.length === 0) return Promise.resolve(false);

    var actions = [];
    var requiresReload = false;
    var lastCartResult = null;
    var desiredByGiftVariant = {};

    var hadAnyAutoGift = ((cart && cart.items) || []).some(function (item) {
      return item && item.properties && item.properties[PROP_KEY] === PROP_VAL;
    });

    rules.forEach(function (rule) {
      if (!rule || !rule.mainVariantId || !rule.giftVariantId) return;
      var mainQty = getCartQtyByVariant(cart, rule.mainVariantId);
      if (!desiredByGiftVariant[rule.giftVariantId]) {
        desiredByGiftVariant[rule.giftVariantId] = {
          quantity: 0,
          primaryMainVariantId: String(rule.mainVariantId),
        };
      }
      desiredByGiftVariant[rule.giftVariantId].quantity += mainQty;
    });

    Object.keys(desiredByGiftVariant).forEach(function (giftVariantId) {
      var entry = desiredByGiftVariant[giftVariantId];
      var manualGift = hasManualGift(cart, giftVariantId);
      var desiredQty = manualGift ? 0 : entry.quantity;
      var giftLines = getAutoGiftLines(cart, giftVariantId);
      var currentQty = giftLines.reduce(function (sum, line) {
        return sum + (line.quantity || 0);
      }, 0);

      if (giftLines.length === 0) {
        if (desiredQty > 0) {
          // On many themes the cart PAGE HTML won't update to show the new line item.
          // Trigger a one-time refresh when we add the first auto-gift.
          if (!hadAnyAutoGift) requiresReload = true;
          actions.push(function () {
            return postCart(cartEndpoint('cart/add.js'), {
              id: giftVariantId,
              quantity: desiredQty,
              properties: {
                _gwp: '1',
                _gwp_main: String(entry.primaryMainVariantId),
              },
            });
          });
        }
        return;
      }

      if (desiredQty === 0) {
        giftLines.forEach(function (giftLine) {
          if ((giftLine.quantity || 0) > 0) {
            actions.push(function () {
              return postCart(cartEndpoint('cart/change.js'), { id: giftLine.key, quantity: 0 });
            });
          }
        });
        return;
      }

      if (currentQty !== desiredQty) {
        actions.push(function () {
          return postCart(cartEndpoint('cart/change.js'), { id: giftLines[0].key, quantity: desiredQty });
        });
      }

      giftLines.slice(1).forEach(function (giftLine) {
        if ((giftLine.quantity || 0) > 0) {
          actions.push(function () {
            return postCart(cartEndpoint('cart/change.js'), { id: giftLine.key, quantity: 0 });
          });
        }
      });
    });

    if (actions.length === 0) return Promise.resolve(false);

    var p = Promise.resolve();
    actions.forEach(function (fn) {
      p = p
        .then(function () { return fn(); })
        .then(function (res) { if (res) lastCartResult = res; return null; })
        .catch(function () { return null; });
    });

    return p.then(function () {
      return { didChange: true, requiresReload: requiresReload, lastCartResult: lastCartResult };
    });
  }

  function maybeReloadCartPage(cart) {
    if (!window.location || !/^\/cart\b/.test(window.location.pathname || '')) return false;
    var token = (cart && cart.token) ? String(cart.token) : '';
    var key = cartReloadKeyPrefix + token;
    try {
      if (sessionStorage.getItem(key) === '1') return false;
      sessionStorage.setItem(key, '1');
    } catch (e) {}
    window.location.reload();
    return true;
  }

  function refreshCartSectionsAjax() {
    var ids = getCartSectionIds();
    if (!ids || ids.length === 0) return Promise.resolve(false);

    // Re-render the sections in the context of the current page.
    var path = (window.location && window.location.pathname) ? String(window.location.pathname) : '/';
    var qs = (window.location && window.location.search) ? String(window.location.search) : '';
    var sep = (qs && qs.indexOf('?') === 0) ? '&' : '?';
    var url = path + qs + sep + 'sections=' + encodeURIComponent(ids.join(','));
    return fetch(url, { cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (sections) {
        if (!sections) return false;
        var replacedAny = false;
        ids.forEach(function (id) {
          var html = sections[id];
          if (!html) return;
          var el = document.getElementById('shopify-section-' + id);
          if (!el) return;

          // Shopify may return either the section's inner HTML or the full wrapper element.
          var tmp = document.createElement('div');
          tmp.innerHTML = html;
          var wrapper = tmp.querySelector('#shopify-section-' + id);
          if (wrapper && wrapper.parentNode) {
            el.replaceWith(wrapper);
          } else {
            el.innerHTML = html;
          }
          replacedAny = true;
        });
        if (replacedAny) {
          // Re-run any listeners that rely on cart HTML being present
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          try { ensurePortals(); } catch (e) {}
        }
        return replacedAny;
      })
      .catch(function () { return false; });
  }

  function applyCartSections(sections) {
    if (!sections) return false;

    var replacedAny = false;
    getCartSectionIds().forEach(function (id) {
      var html = sections[id];
      if (!html) return;
      var el = document.getElementById('shopify-section-' + id);
      if (!el) return;

      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      var wrapper = tmp.querySelector('#shopify-section-' + id);
      if (wrapper && wrapper.parentNode) {
        el.replaceWith(wrapper);
      } else {
        el.innerHTML = html;
      }
      replacedAny = true;
    });

    if (replacedAny) {
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      document.dispatchEvent(new CustomEvent('cart:updated'));
    }

    return replacedAny;
  }

  function tryRenderThemeCart(cart) {
    if (!cart || !cart.sections) return;
    try {
      var drawer = document.querySelector('cart-drawer');
      if (drawer && typeof drawer.renderContents === 'function') drawer.renderContents(cart);
    } catch (e) {}

    try {
      var notif = document.querySelector('cart-notification');
      if (notif && typeof notif.renderContents === 'function') notif.renderContents(cart);
    } catch (e) {}
  }

  // Per-session dedup: only show toast once per gift variant per session
  var seenKey = 'gwp_seen_v1';
  var seen;
  try { seen = new Set(JSON.parse(sessionStorage.getItem(seenKey) || '[]')); }
  catch (e) { seen = new Set(); }

  // Keep toast/confetti outside cart sections so AJAX replacement can't remove them.
  function ensurePortals() {
    try {
      var toasts = Array.prototype.slice.call(document.querySelectorAll('#gwp-toast'));
      var toast = toasts[toasts.length - 1];
      toasts.slice(0, -1).forEach(function (el) { try { el.remove(); } catch (e) {} });
      if (toast && toast.parentNode !== document.body) document.body.appendChild(toast);

      var confettis = Array.prototype.slice.call(document.querySelectorAll('#gwp-confetti'));
      var confetti = confettis[confettis.length - 1];
      confettis.slice(0, -1).forEach(function (el) { try { el.remove(); } catch (e) {} });
      if (confetti && confetti.parentNode !== document.body) document.body.appendChild(confetti);
    } catch (e) {}
  }
  ensurePortals();

  function persistSeen() {
    try { sessionStorage.setItem(seenKey, JSON.stringify(Array.from(seen))); } catch (e) {}
  }

  // ── Banner rendering ──────────────────────────────────────────────────────

  function renderBanner(gifts) {
    var jsBanner  = document.getElementById('gwp-banner-js');
    var ssrBanner = document.getElementById('gwp-banner-ssr');

    if (gifts.length === 0) {
      if (jsBanner)  jsBanner.style.display  = 'none';
      if (ssrBanner) ssrBanner.style.display = 'none';
      return;
    }

    // SSR banner already has the correct content — leave it visible
    if (ssrBanner && ssrBanner.offsetParent !== null) return;

    if (!jsBanner) return;

    jsBanner.innerHTML = gifts.map(function (item) {
      var imgTag = '';
      if (item.featured_image && item.featured_image.url) {
        // Append Shopify image sizing param
        var imgSrc = item.featured_image.url.split('?')[0] + '?width=80';
        imgTag = '<img class="gwp-banner-img" src="' + imgSrc + '" alt="" loading="lazy" width="44" height="44" />';
      } else {
        imgTag = '<span class="gwp-banner-icon">&#127873;</span>';
      }
      return (
        '<div class="gwp-banner-item">' +
          imgTag +
          '<div class="gwp-banner-text">' +
            '<strong>' + getNotifText() + '</strong>' +
            '<span>' + item.product_title + ' added to your cart for free.</span>' +
          '</div>' +
          '<span class="gwp-banner-free-badge">FREE</span>' +
        '</div>'
      );
    }).join('');

    jsBanner.style.display = 'flex';
  }

  // ── Toast ─────────────────────────────────────────────────────────────────

  function showToast(gift) {
    var key = String(gift.variant_id);
    if (seen.has(key)) return;
    seen.add(key);
    persistSeen();

    var toast = document.getElementById('gwp-toast');
    if (!toast) return;

    toast.innerHTML =
      '<span class="gwp-toast-emoji">&#127873;</span>' +
      '<div class="gwp-toast-body">' +
        '<strong>' + getToastText() + '</strong>' +
        '<span>' + gift.product_title + '</span>' +
      '</div>' +
      '<button class="gwp-toast-close" aria-label="Dismiss">&#10005;</button>';

    toast.querySelector('.gwp-toast-close').addEventListener('click', function () {
      toast.classList.remove('gwp-toast--visible');
    });

    // Double-rAF forces browser to paint the initial transform before transitioning
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        toast.classList.add('gwp-toast--visible');
      });
    });

    setTimeout(function () {
      toast.classList.remove('gwp-toast--visible');
    }, 5000);
  }

  function showInfoToast(title, subtitle) {
    if (!getEnableCelebration()) return;
    var toast = document.getElementById('gwp-toast');
    if (!toast) return;

    toast.innerHTML =
      '<span class="gwp-toast-emoji">&#127881;</span>' +
      '<div class="gwp-toast-body">' +
        '<strong>' + (title || 'Congratulations!') + '</strong>' +
        '<span>' + (subtitle || 'Adding your free gift...') + '</span>' +
      '</div>' +
      '<button class="gwp-toast-close" aria-label="Dismiss">&#10005;</button>';

    toast.querySelector('.gwp-toast-close').addEventListener('click', function () {
      toast.classList.remove('gwp-toast--visible');
    });

    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        toast.classList.add('gwp-toast--visible');
      });
    });

    setTimeout(function () {
      toast.classList.remove('gwp-toast--visible');
    }, 1800);
  }

  function burstConfetti() {
    if (!getEnableCelebration()) return;
    var host = document.getElementById('gwp-confetti');
    if (!host) return;
    host.classList.add('gwp-confetti--visible');
    host.innerHTML = '';

    var colors = ['#16a34a', '#22c55e', '#34d399', '#60a5fa', '#a78bfa', '#f59e0b', '#f97316'];
    var count = 26;

    for (var i = 0; i < count; i++) {
      var piece = document.createElement('div');
      piece.className = 'gwp-confetti-piece';
      piece.style.left = (Math.random() * 100) + 'vw';
      piece.style.background = colors[i % colors.length];
      piece.style.setProperty('--dx', ((Math.random() * 120) - 60) + 'px');
      piece.style.setProperty('--rot', ((Math.random() * 720) - 360) + 'deg');
      piece.style.animationDuration = (700 + Math.random() * 500) + 'ms';
      piece.style.width = (8 + Math.random() * 6) + 'px';
      piece.style.height = (10 + Math.random() * 10) + 'px';
      host.appendChild(piece);
    }

    setTimeout(function () {
      host.classList.remove('gwp-confetti--visible');
      host.innerHTML = '';
    }, 1200);
  }

  // ── Cart check ────────────────────────────────────────────────────────────

  var pendingCheck = 0;

  function processCart(cart) {
    loadRules().then(function (rules) {
      if (syncInFlight) { syncQueued = true; return; }
      syncInFlight = true;
      return syncGifts(cart, rules)
        .then(function (result) {
          syncInFlight = false;
          var didChange = result && result.didChange;
          var requiresReload = result && result.requiresReload;
          var lastCartResult = result && result.lastCartResult;
          if (didChange && requiresReload) {
            showInfoToast('Congratulations!', 'Adding your free gift...');
            burstConfetti();
          }

          if (didChange) {
            if (lastCartResult && lastCartResult.sections) {
              var applied = applyCartSections(lastCartResult.sections);
              if (applied) {
                ensurePortals();
                if (lastCartResult && Array.isArray(lastCartResult.items)) {
                  tryRenderThemeCart(lastCartResult);
                  updateGiftUI(lastCartResult);
                } else {
                  checkCart(0);
                }
                return;
              }
            }

            refreshCartSectionsAjax().then(function (ok) {
              if (!ok) maybeReloadCartPage(cart);
              // After section refresh, re-fetch once if needed to re-sync quantities (rare).
              checkCart(80);
            });
            return;
          }

          if (syncQueued) {
            syncQueued = false;
            checkCart(80);
          }
        })
        .catch(function () { syncInFlight = false; });
    });

    updateGiftUI(cart);
  }

  function updateGiftUI(cart) {
    var gifts = (cart && cart.items || []).filter(function (item) {
      return item && item.properties && item.properties[PROP_KEY] === PROP_VAL;
    });
    renderBanner(gifts);
    if (gifts.length > 0) showToast(gifts[0]);
  }

  function checkCart(delay) {
    var token = ++pendingCheck;
    setTimeout(function () {
      if (token !== pendingCheck) return;
      fetch(cartEndpoint('cart.js'), { cache: 'no-store' })
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          if (token !== pendingCheck) return;
          processCart(cart);
          return;
        })
        .catch(function () {});
    }, delay || 0);
  }

  // ── Event listeners ───────────────────────────────────────────────────────

  // Common cart events across popular themes
  [
    'cart:updated',
    'cart:refresh',
    'cart:change',
    'cart-items-added',           // Dawn
    'CartDrawer:AfterItemAdded',  // some themes
    'shopify:cart:updated',
    'on:cart:add',                // Impulse / Prestige
  ].forEach(function (ev) {
    document.addEventListener(ev, function () { checkCart(80); });
  });

  // Intercept fetch — catches themes that call /cart/add.js, /cart/change.js, etc.
  var _origFetch = window.fetch;
  window.fetch = function (input) {
    var result = _origFetch.apply(this, arguments);
    var url = typeof input === 'string' ? input : (input && input.url) || '';

    function hasInternalHeader(obj) {
      try {
        if (!obj) return false;
        var h = obj.headers;
        if (!h) return false;
        if (typeof h.get === 'function') return String(h.get('X-GWP-Internal') || '') === '1';
        if (Array.isArray(h)) return h.some(function (kv) { return kv && String(kv[0] || '').toLowerCase() === 'x-gwp-internal' && String(kv[1] || '') === '1'; });
        if (typeof h === 'object') {
          var v = h['X-GWP-Internal'] || h['x-gwp-internal'];
          return String(v || '') === '1';
        }
      } catch (e) {}
      return false;
    }

    var init = arguments.length > 1 ? arguments[1] : null;
    var isInternal = hasInternalHeader(init) || (input && typeof input !== 'string' && hasInternalHeader(input));

    if (!isInternal && /\/cart\/(add|change|update|clear)(\.js)?/.test(url)) {
      result.then(function (res) {
        try {
          var cloned = res.clone();
          var ct = (cloned.headers && cloned.headers.get && cloned.headers.get('content-type')) || '';
          if (ct && ct.indexOf('application/json') !== -1) {
            cloned.json().then(function (cart) {
              if (cart && cart.items) processCart(cart);
              else checkCart(80);
            }).catch(function () { checkCart(80); });
            return;
          }
        } catch (e) {}
        checkCart(80);
      }).catch(function () {});
    }
    return result;
  };

  // Intercept XHR — catches themes that use jQuery.ajax or plain XHR
  var _origOpen = XMLHttpRequest.prototype.open;
  XMLHttpRequest.prototype.open = function (method, url) {
    if (typeof url === 'string' && /\/cart\/(add|change|update|clear)(\.js)?/.test(url)) {
      this.addEventListener('load', function () {
        try {
          var txt = this.responseText;
          if (txt && typeof txt === 'string' && txt[0] === '{') {
            var cart = JSON.parse(txt);
            if (cart && cart.items) { processCart(cart); return; }
          }
        } catch (e) {}
        checkCart(80);
      });
    }
    return _origOpen.apply(this, arguments);
  };

  // Initial check
  loadRules();
  checkCart(0);
})();
</script>

{% schema %}
{
  "name": "Gift Notification",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "notification_text",
      "label": "Banner heading",
      "info": "Shown inside the cart above the gift product name.",
      "default": "You've earned a free gift!"
    },
    {
      "type": "text",
      "id": "toast_text",
      "label": "Toast heading",
      "info": "Shown in the slide-in popup when a gift is first added.",
      "default": "Free gift added!"
    },
    {
      "type": "checkbox",
      "id": "enable_celebration",
      "label": "Enable celebration",
      "info": "Shows a short congratulations toast + confetti when a gift is added.",
      "default": false
    },
    {
      "type": "text",
      "id": "api_base_url",
      "label": "App API base URL",
      "info": "Your app's public URL (used to fetch gift rules). Example: https://upsale-cyan.vercel.app",
      "default": "https://upsale-cyan.vercel.app"
    },
    {
      "type": "text",
      "id": "cart_section_ids",
      "label": "Cart section IDs",
      "info": "Comma-separated section IDs to re-render via AJAX after adding gifts. Dawn defaults: main-cart-items,main-cart-footer",
      "default": "main-cart-items,main-cart-footer"
    }
  ]
}
{% endschema %}
