{% comment %} Upsale — Upsell Widget {% endcomment %}

<div id="upsale-root" data-product-id="{{ product.id }}" data-shop="{{ shop.permanent_domain }}" data-currency="{{ shop.currency }}" style="display:none; margin: 1.25rem 0;">

  <style>
    #upsale-root * { box-sizing: border-box; }
    #upsale-card {
      border: 2px solid #008060;
      border-radius: 12px;
      overflow: hidden;
      background: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    #upsale-header {
      background: #008060;
      padding: 0.5rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    #upsale-header span {
      color: #fff;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    #upsale-body {
      padding: 1rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    #upsale-img {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 8px;
      flex-shrink: 0;
      display: none;
    }
    #upsale-img-placeholder {
      width: 80px;
      height: 80px;
      background: #f1f1f1;
      border-radius: 8px;
      flex-shrink: 0;
    }
    #upsale-info { flex: 1; min-width: 0; }
    #upsale-message { margin: 0 0 0.25rem; font-size: 0.8rem; color: #6d7175; }
    #upsale-title { margin: 0 0 0.4rem; font-size: 0.95rem; font-weight: 600; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    #upsale-prices { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    #upsale-price { font-size: 1rem; font-weight: 700; color: #008060; }
    #upsale-original { font-size: 0.85rem; color: #9ca3af; text-decoration: line-through; display: none; }
    #upsale-badge { font-size: 0.7rem; font-weight: 700; background: #fef3c7; color: #92400e; padding: 0.15rem 0.5rem; border-radius: 20px; display: none; }
    #upsale-btn {
      flex-shrink: 0;
      padding: 0.65rem 1.25rem;
      background: #008060;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
      white-space: nowrap;
    }
    #upsale-btn:hover { background: #006e52; }
    #upsale-btn:disabled { background: #9ca3af; cursor: not-allowed; }
    #upsale-added {
      display: none;
      flex-shrink: 0;
      padding: 0.65rem 1.25rem;
      background: #e3f1df;
      color: #1a6b3c;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
    }
  </style>

  <div id="upsale-card">
    <div id="upsale-header">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="#fff"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
      <span id="upsale-header-text">Frequently bought together</span>
    </div>
    <div id="upsale-body">
      <img id="upsale-img" src="" alt="" width="80" height="80" />
      <div id="upsale-img-placeholder"></div>
      <div id="upsale-info">
        <p id="upsale-message"></p>
        <p id="upsale-title"></p>
        <div id="upsale-prices">
          <span id="upsale-price"></span>
          <span id="upsale-original"></span>
          <span id="upsale-badge"></span>
        </div>
      </div>
      <button id="upsale-btn">Add to cart</button>
      <div id="upsale-added">✓ Added!</div>
    </div>
  </div>

</div>

<script>
(function () {
  var root = document.getElementById('upsale-root');
  if (!root) return;

  var shop = root.dataset.shop;
  var productId = root.dataset.productId;
  var currency = root.dataset.currency;
  var apiBase = ({{ settings.api_base | json }} || 'https://upsale-cyan.vercel.app').replace(/\/$/, '');

  if (!shop || !productId) return;

  var fmt = function (n) {
    try {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency || 'USD' }).format(n);
    } catch (e) {
      return currency + ' ' + parseFloat(n).toFixed(2);
    }
  };

  fetch(apiBase + '/api/upsell?shop=' + encodeURIComponent(shop) + '&product_id=' + productId)
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data || !data.upsell) return;
      var u = data.upsell;

      // Populate content
      document.getElementById('upsale-message').textContent = u.message || '';
      document.getElementById('upsale-title').textContent = u.title || '';
      document.getElementById('upsale-price').textContent = fmt(u.price);

      if (u.discountPercent > 0) {
        var orig = document.getElementById('upsale-original');
        orig.textContent = fmt(u.originalPrice);
        orig.style.display = 'inline';
        var badge = document.getElementById('upsale-badge');
        badge.textContent = u.discountPercent + '% OFF';
        badge.style.display = 'inline';
      }

      if (u.image) {
        var img = document.getElementById('upsale-img');
        img.src = u.image;
        img.alt = u.title;
        img.style.display = 'block';
        document.getElementById('upsale-img-placeholder').style.display = 'none';
      }

      // Show widget immediately — don't wait for variant fetch
      root.style.display = 'block';

      // Get variant ID for Add to Cart
      var btn = document.getElementById('upsale-btn');
      fetch('/products/' + u.handle + '.js')
        .then(function (r) { return r.json(); })
        .then(function (product) {
          var variantId = product.variants && product.variants[0] && product.variants[0].id;
          if (!variantId) { btn.textContent = 'View product'; btn.addEventListener('click', function () { window.location.href = '/products/' + u.handle; }); return; }
          btn.addEventListener('click', function () {
            btn.disabled = true;
            btn.textContent = 'Adding…';
            fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: variantId, quantity: 1 })
            })
            .then(function (r) {
              if (!r.ok) throw new Error('failed');
              btn.style.display = 'none';
              document.getElementById('upsale-added').style.display = 'block';
              document.dispatchEvent(new CustomEvent('cart:refresh'));
            })
            .catch(function () {
              btn.disabled = false;
              btn.textContent = 'Add to cart';
            });
          });
        })
        .catch(function () {
          btn.textContent = 'View product';
          btn.addEventListener('click', function () { window.location.href = '/products/' + u.handle; });
        });
    })
    .catch(function () {});
})();
</script>

{% schema %}
{
  "name": "Upsell Widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_base",
      "label": "App URL",
      "info": "Your Upsale app URL",
      "default": "https://upsale-cyan.vercel.app"
    },
    {
      "type": "text",
      "id": "header_text",
      "label": "Header label",
      "default": "Frequently bought together"
    }
  ]
}
{% endschema %}
